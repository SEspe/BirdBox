# ESP-IDF build artifacts
build/
*.bin
*.elf
*.map
*.hex

# ESP-IDF generated files (regenerated from sdkconfig.defaults / idf_component.yml)
sdkconfig
sdkconfig.old
dependencies.lock
managed_components/

# IDE files
.vscode/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.pyc

# Local training-data archive for the Nordic species retrain (FSD §3.2.1) -
# the actual photos and per-machine pull state, not source, kept out of the
# firmware repo; the pull script and README are real tooling and stay tracked
training-data/lavskrike/
training-data/not-lavskrike/
training-data/manifest.txt
training-data/dataset/

# Training env + trained-model outputs (train.py) — big binaries / venv, not
# source. The script, requirements.txt and README stay tracked.
training-data/.venv/
training-data/*.tflite
training-data/*-v*.txt
training-data/*-v*.json
# downloaded detector weights (e.g. yolov8n.pt)
training-data/*.pt
